<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UFOLEP84.App.Pages.GqsSessionsPage"
             Title="Sessions GQS">

    <Grid RowDefinitions="Auto,Auto,*" Padding="12" RowSpacing="12" BackgroundColor="{StaticResource AppBgBrush}">
        <HorizontalStackLayout Spacing="10">
            <Button Text="Rafraîchir" Clicked="OnRefreshClicked" />
            <Label x:Name="InfoLabel" VerticalTextAlignment="Center" />
        </HorizontalStackLayout>

        <Border Grid.Row="1" BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" Stroke="Transparent" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Grid Padding="10" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label Text="Astuce" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#312E81, Dark=White}" />
                <Label Grid.Column="1" Text="Tap sur une session pour voir les participants (ou swipe vers la droite)." TextColor="{AppThemeBinding Light=#312E81, Dark=White}" />
            </Grid>
        </Border>

        <CollectionView x:Name="SessionsView" Grid.Row="2" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.LeftItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Participants" BackgroundColor="{StaticResource BrandBlueBrush}" Invoked="OnOpenInvoked" CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.LeftItems>

                        <Border Stroke="{Binding BorderColor}"
                                StrokeThickness="2"
                            BackgroundColor="{StaticResource CardBgBrush}"
                                Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#1F2937" Opacity="0.12" Offset="0,6" Radius="14" />
                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSessionTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid Padding="14" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8">
                                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding DisplayDate}" FontAttributes="Bold" FontSize="18" />
                                    <Label Text="{Binding Session.Formateur}" FontSize="13" TextColor="{StaticResource TextSecondaryBrush}" />
                                    <Label Text="{Binding Session.Lieu}" FontSize="13" TextColor="{StaticResource TextTertiaryBrush}" />
                                </VerticalStackLayout>

                                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="{Binding BadgeBackground}" Padding="10,6" IsVisible="{Binding HasBadge}" HorizontalOptions="End" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="999" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding BadgeText}" FontSize="12" TextColor="White" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="Inscrits" FontSize="12" TextColor="{StaticResource TextTertiaryBrush}" />
                                        <Label Text="{Binding Session.ParticipantsCount}" FontSize="16" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                                        <Label Text="Places restantes" FontSize="12" TextColor="{StaticResource TextTertiaryBrush}" />
                                        <Label Text="{Binding Session.PlacesRestantes}" FontSize="16" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
