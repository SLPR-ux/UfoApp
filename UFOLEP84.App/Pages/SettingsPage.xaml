<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UFOLEP84.App.Pages.SettingsPage"
             Title="Paramètres">

    <VerticalStackLayout Padding="20" Spacing="12">
        <Label Text="API" FontSize="18" FontAttributes="Bold" />
        <Label Text="URL de base (doit se terminer par /API)" FontSize="12" TextColor="#555" />

        <Entry x:Name="ApiBaseUrlEntry" Placeholder="https://ufolep84.fr/API" />

        <HorizontalStackLayout Spacing="10">
            <Button Text="Enregistrer" Clicked="OnSaveClicked" />
            <Button Text="Réinitialiser" Clicked="OnResetClicked" />
            <Button Text="Tester" Clicked="OnTestClicked" />
        </HorizontalStackLayout>

        <Label x:Name="StatusLabel" TextColor="#B71C1C" IsVisible="False" />

        <Frame Padding="12" CornerRadius="10" HasShadow="True">
            <VerticalStackLayout Spacing="6">
                <Label Text="Astuce" FontAttributes="Bold" />
                <Label Text="En local (Windows/WAMP), l’URL ressemble souvent à :" FontSize="12" />
                <Label Text="http://localhost/UFO/ufolep84.fr/API" FontSize="12" TextColor="#333" />
                <Label Text="Sur Android (émulateur), 'localhost' ne marche pas : utilisez plutôt :" FontSize="12" />
                <Label Text="http://10.0.2.2/UFO/ufolep84.fr/API" FontSize="12" TextColor="#333" />
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>
