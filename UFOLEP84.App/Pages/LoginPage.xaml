<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UFOLEP84.App.Pages.LoginPage"
             Title="Connexion">

    <VerticalStackLayout Padding="20" Spacing="12">
        <Label Text="Connexion employé UFOLEP84"
               FontSize="20"
               FontAttributes="Bold" />

        <Entry x:Name="UsernameEntry" Placeholder="Nom d'utilisateur" />
        <Entry x:Name="PasswordEntry" Placeholder="Mot de passe" IsPassword="True" />

        <Button Text="Se connecter"
                Clicked="OnLoginClicked" />

       <Button Text="Paramètres (URL API)"
              Clicked="OnOpenSettingsClicked" />

        <Label x:Name="StatusLabel"
               TextColor="DarkRed"
               IsVisible="False" />
    </VerticalStackLayout>
</ContentPage>
